# TaskForge Backend - Environment Configuration
# Copy to .env and fill in values. Never commit .env.
#
# Production: You MUST set DATABASE_URL and SECRET_KEY.
# Generate SECRET_KEY: openssl rand -hex 32

# Database (required for production)
DATABASE_URL=postgresql://taskforge:taskforge@localhost:5432/taskforge

# Security (REQUIRED for production - never use default)
SECRET_KEY=your-secret-key-change-in-production

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App (DEBUG=true for local dev only)
DEBUG=false
LOG_LEVEL=INFO
