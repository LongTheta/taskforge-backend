# TaskForge Backend - Environment Configuration
# Copy to .env and fill in values. Never commit .env.
#
# Production: APP_ENV=production, DATABASE_URL and SECRET_KEY required.
# Generate SECRET_KEY: openssl rand -hex 32

# Environment: development | production | test
APP_ENV=development

# Database (required for production; local default for dev)
DATABASE_URL=postgresql://taskforge:taskforge@localhost:5432/taskforge

# Security (REQUIRED for production - startup fails if insecure)
# Do NOT use: change-me-in-production, your-secret-key-change-in-production,
# dev-secret-key-change-in-production. Generate: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32-output

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting (set RATE_LIMIT_ENABLED=false to disable, e.g. in tests)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=100

# MFA (future: when implemented, set true to require TOTP for admin)
# MFA_REQUIRED_FOR_ADMIN=false

# N8N webhook for email/SMS notifications (optional)
# Set to N8N Webhook trigger URL to receive: login_failure, mfa_enabled, user_registered
# NOTIFICATION_WEBHOOK_URL=https://your-n8n.instance/webhook/xxx

# App
DEBUG=false
LOG_LEVEL=INFO

# Build / deployment metadata (optional; set by CI or GitOps)
# GIT_SHA=abc1234
# IMAGE_TAG=0.1.0
